{
  "product_name": "Non-EU Trade Flows (ONS/StatCan)",
  "product_code": "trade_flows_non_eu",
  "vault_path": "gs://lekwankwa-vault/product=trade_flows",
  "source_filter": null,
  "source_file_map": {
    "ons_api":       "trade_flows_data.parquet",
    "statcan_csv":   "trade_flows_data.parquet"
  },
  "sources": ["ons_api", "statcan_csv"],
  "description": "Universal GX validation for GBR/CAN merchandise and BOP trade flows",
  "schema_version": "5.0",
  "critical_checks": {
    "row_count": { "min": 100, "max": 500000,
                   "description": "2 countries x exports/imports/balance" },
    "required_columns": [
      "data_vintage_id", "confidence_tier", "sovereign_series_id", "macro_metric_name",
      "reporting_date", "official_release_date", "as_of_date", "observed_value",
      "unit_of_measure", "is_revised_figure", "data_timestamp", "revision_number",
      "iso_alpha3", "country_name", "source", "source_agency", "source_sub_category",
      "sdmx_frequency", "published_date", "data_quality_certified"
    ],
    "non_null_fields": [
      "data_vintage_id", "sovereign_series_id", "macro_metric_name",
      "reporting_date", "observed_value", "iso_alpha3"
    ],
    "value_constraints": {
      "observed_value": {
        "min": -500000000.0, "max": 5000000000.0,
        "description": "Trade values in domestic currency (GBP/CAD)"
      }
    },
    "categorical_constraints": {
      "iso_alpha3":     ["GBR", "CAN"],
      "source_agency":  ["ONS", "STATCAN"],
      "source":         ["ons_api", "statcan_csv"],
      "confidence_tier": ["PRIMARY", "DERIVED"]
    },
    "timestamp_checks": {
      "reporting_date": { "min_year": 1988, "max_year": 2027, "format": "datetime64" }
    }
  }
}
