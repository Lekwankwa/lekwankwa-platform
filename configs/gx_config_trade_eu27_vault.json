{
  "product_name": "EU27 Trade Flows (Eurostat National Accounts)",
  "product_code": "trade_eu27",
  "vault_path": "gs://lekwankwa-vault/product=trade_flows",
  "source_filter": "eurostat_sdmx",
  "excluded_countries": ["USA"],
  "description": "Universal validation for EU27 exports and imports of goods and services from Eurostat SDMX",
  "sources": ["eurostat_sdmx"],
  "schema_version": "5.0",
  "critical_checks": {
    "row_count": {
      "min": 5000,
      "max": 5000000,
      "description": "27 EU countries x exports + imports from 2000-2026 (quarterly + CF fill)"
    },
    "required_columns": [
      "data_vintage_id",
      "confidence_tier",
      "sovereign_series_id",
      "macro_metric_name",
      "reporting_date",
      "official_release_date",
      "as_of_date",
      "observed_value",
      "unit_of_measure",
      "is_revised_figure",
      "data_timestamp",
      "revision_number",
      "iso_alpha3",
      "country_name",
      "source",
      "source_agency",
      "source_sub_category",
      "sdmx_frequency",
      "published_date",
      "data_quality_certified"
    ],
    "non_null_fields": [
      "data_vintage_id",
      "sovereign_series_id",
      "macro_metric_name",
      "reporting_date",
      "observed_value",
      "iso_alpha3",
      "source_agency",
      "data_quality_certified"
    ],
    "value_constraints": {
      "observed_value": {
        "min": 0.0,
        "max": 1500000.0,
        "description": "Quarterly trade flows in million EUR — Germany exceeds EUR 500B/quarter"
      }
    },
    "categorical_constraints": {
      "iso_alpha3": ["AUT","BEL","BGR","HRV","CYP","CZE","DNK","EST","FIN","FRA","DEU","GRC","HUN","IRL","ITA","LVA","LTU","LUX","MLT","NLD","POL","PRT","ROU","SVK","SVN","ESP","SWE"],
      "source_agency": ["EUROSTAT"],
      "source": ["eurostat_sdmx"],
      "confidence_tier": ["PRIMARY", "DERIVED"],
      "data_quality_certified": [true, false]
    },
    "timestamp_checks": {
      "reporting_date": {
        "min_year": 1998,
        "max_year": 2027,
        "format": "datetime64",
        "description": "Trade flows start from ~2000 for most EU countries"
      }
    }
  }
}
