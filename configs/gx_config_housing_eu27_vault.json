{
  "product_name": "EU27 Housing Supply & Shelter Inflation (Eurostat)",
  "product_code": "housing_eu27",
  "vault_path": "gs://lekwankwa-vault/product=Housing_Supply_and_Shelter_Inflation",
  "source_filter": "eurostat_sdmx",
  "excluded_countries": ["USA"],
  "description": "Universal validation for EU27 HPI, building permits and HICP rent data from Eurostat SDMX",
  "sources": ["eurostat_sdmx"],
  "schema_version": "5.0",
  "critical_checks": {
    "row_count": {
      "min": 5000,
      "max": 5000000,
      "description": "27 EU countries x HPI + permits + HICP rent from 2000-2026"
    },
    "required_columns": [
      "data_vintage_id",
      "confidence_tier",
      "sovereign_series_id",
      "macro_metric_name",
      "reporting_date",
      "official_release_date",
      "as_of_date",
      "observed_value",
      "unit_of_measure",
      "is_revised_figure",
      "data_timestamp",
      "revision_number",
      "iso_alpha3",
      "country_name",
      "source",
      "source_agency",
      "source_sub_category",
      "sdmx_frequency",
      "published_date",
      "data_quality_certified"
    ],
    "non_null_fields": [
      "data_vintage_id",
      "sovereign_series_id",
      "macro_metric_name",
      "reporting_date",
      "observed_value",
      "iso_alpha3",
      "source_agency",
      "data_quality_certified"
    ],
    "value_constraints": {
      "observed_value": {
        "min": 0.0,
        "max": 10000.0,
        "description": "Index values (2015=100), permit counts in thousands, HICP index. Building permit indices for ESP/GRC/PRT/SVN/FIN legitimately reach 2000-9300 during the 2004-2007 pre-crisis construction boom relative to the depressed 2015 baseline."
      }
    },
    "categorical_constraints": {
      "iso_alpha3": ["AUT","BEL","BGR","HRV","CYP","CZE","DNK","EST","FIN","FRA","DEU","GRC","HUN","IRL","ITA","LVA","LTU","LUX","MLT","NLD","POL","PRT","ROU","SVK","SVN","ESP","SWE"],
      "source_agency": ["EUROSTAT"],
      "source": ["eurostat_sdmx"],
      "confidence_tier": ["PRIMARY", "DERIVED"],
      "data_quality_certified": [true, false]
    },
    "timestamp_checks": {
      "reporting_date": {
        "min_year": 2000,
        "max_year": 2027,
        "format": "datetime64",
        "description": "Housing data generally starts from 2000 for EU countries"
      }
    }
  }
}
