{
  "product_name": "Non-EU Housing Supply & Shelter Inflation (ONS/StatCan/ABS)",
  "product_code": "housing_non_eu",
  "vault_path": "gs://lekwankwa-vault/product=Housing_Supply_and_Shelter_Inflation",
  "source_filter": null,
  "source_file_map": {
    "ons_api":     "housing_data.parquet",
    "statcan_csv": "housing_data.parquet",
    "abs_sdmx":    "housing_data.parquet"
  },
  "sources": ["ons_api", "statcan_csv", "abs_sdmx"],
  "description": "Universal GX validation for GBR/CAN/AUS housing (NOR excluded — no confirmed table)",
  "schema_version": "5.0",
  "critical_checks": {
    "row_count": { "min": 50, "max": 100000,
                   "description": "3 countries: GBR CPI housing, CAN NHPI, AUS RPPI" },
    "required_columns": [
      "data_vintage_id", "confidence_tier", "sovereign_series_id", "macro_metric_name",
      "reporting_date", "official_release_date", "as_of_date", "observed_value",
      "unit_of_measure", "is_revised_figure", "data_timestamp", "revision_number",
      "iso_alpha3", "country_name", "source", "source_agency", "source_sub_category",
      "sdmx_frequency", "published_date", "data_quality_certified"
    ],
    "non_null_fields": [
      "data_vintage_id", "sovereign_series_id", "macro_metric_name",
      "reporting_date", "observed_value", "iso_alpha3"
    ],
    "value_constraints": {
      "observed_value": {
        "min": 0.0, "max": 1500.0,
        "description": "Housing price indices and CPI shelter components"
      }
    },
    "categorical_constraints": {
      "iso_alpha3":     ["GBR", "CAN", "AUS"],
      "source_agency":  ["ONS", "STATCAN", "ABS"],
      "source":         ["ons_api", "statcan_csv", "abs_sdmx"],
      "confidence_tier": ["PRIMARY", "DERIVED"]
    },
    "timestamp_checks": {
      "reporting_date": { "min_year": 1981, "max_year": 2027, "format": "datetime64" }
    }
  }
}
