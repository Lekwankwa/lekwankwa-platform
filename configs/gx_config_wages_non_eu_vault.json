{
  "product_name": "Non-EU Wages & Employment (ONS/StatCan)",
  "product_code": "wages_and_employment_non_eu",
  "vault_path": "gs://lekwankwa-vault/product=wages_and_employment",
  "source_filter": null,
  "source_file_map": {
    "ons_api":       "wages_employment_data.parquet",
    "statcan_csv":   "wages_employment_data.parquet"
  },
  "sources": ["ons_api", "statcan_csv"],
  "description": "Universal GX validation for GBR/CAN wages and employment",
  "schema_version": "5.0",
  "critical_checks": {
    "row_count": { "min": 500, "max": 500000,
                   "description": "2 countries x multiple series" },
    "required_columns": [
      "data_vintage_id", "confidence_tier", "sovereign_series_id", "macro_metric_name",
      "reporting_date", "official_release_date", "as_of_date", "observed_value",
      "unit_of_measure", "is_revised_figure", "data_timestamp", "revision_number",
      "iso_alpha3", "country_name", "source", "source_agency", "source_sub_category",
      "sdmx_frequency", "published_date", "data_quality_certified"
    ],
    "non_null_fields": [
      "data_vintage_id", "sovereign_series_id", "macro_metric_name",
      "reporting_date", "observed_value", "iso_alpha3", "source_agency"
    ],
    "value_constraints": {
      "observed_value": {
        "min": 0.0, "max": 100000.0,
        "description": "Unemployment rate, employment (thousands), weekly earnings"
      }
    },
    "categorical_constraints": {
      "iso_alpha3":     ["GBR", "CAN"],
      "source_agency":  ["ONS", "STATCAN"],
      "source":         ["ons_api", "statcan_csv"],
      "confidence_tier": ["PRIMARY", "DERIVED"]
    },
    "timestamp_checks": {
      "reporting_date": { "min_year": 1970, "max_year": 2027, "format": "datetime64" }
    }
  }
}
