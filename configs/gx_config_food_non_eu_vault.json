{
  "product_name": "Non-EU Food Micropricing (ONS/StatCan/ABS/SSB)",
  "product_code": "food_micropricing_non_eu",
  "vault_path": "gs://lekwankwa-vault/product=food_micropricing",
  "source_filter": null,
  "source_file_map": {
    "ons_api":       "food_pricing_data.parquet",
    "statcan_csv":   "food_pricing_data.parquet",
    "abs_sdmx":      "food_pricing_data.parquet",
    "ssb_statbank":  "food_pricing_data.parquet"
  },
  "sources": ["ons_api", "statcan_csv", "abs_sdmx", "ssb_statbank"],
  "description": "Universal GX validation for GBR/CAN/AUS/NOR food micropricing CPI sub-components",
  "schema_version": "5.0",
  "critical_checks": {
    "row_count": { "min": 100, "max": 200000,
                   "description": "4 countries x CPI food sub-components" },
    "required_columns": [
      "data_vintage_id", "confidence_tier", "sovereign_series_id", "macro_metric_name",
      "reporting_date", "official_release_date", "as_of_date", "observed_value",
      "unit_of_measure", "is_revised_figure", "data_timestamp", "revision_number",
      "iso_alpha3", "country_name", "source", "source_agency", "source_sub_category",
      "sdmx_frequency", "published_date", "data_quality_certified"
    ],
    "non_null_fields": [
      "data_vintage_id", "sovereign_series_id", "macro_metric_name",
      "reporting_date", "observed_value", "iso_alpha3"
    ],
    "value_constraints": {
      "observed_value": {
        "min": 5.0, "max": 800.0,
        "description": "CPI food index; early-period values can dip below 10"
      }
    },
    "categorical_constraints": {
      "iso_alpha3":     ["GBR", "CAN", "AUS", "NOR"],
      "source_agency":  ["ONS", "STATCAN", "ABS", "SSB"],
      "source":         ["ons_api", "statcan_csv", "abs_sdmx", "ssb_statbank"],
      "confidence_tier": ["PRIMARY", "DERIVED"]
    },
    "timestamp_checks": {
      "reporting_date": { "min_year": 1949, "max_year": 2027, "format": "datetime64" }
    }
  }
}
